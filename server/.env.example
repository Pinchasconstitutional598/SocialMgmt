# Skopiuj do `server/.env` i uzupełnij (plik `server/.env` jest w .gitignore — nie commituj go).
# Windows (PowerShell): Copy-Item .env.example .env
# Uruchamiaj z katalogu server\ lub użyj pełnej ścieżki.

# MySQL — hasło musi być zgodne z MYSQL_ROOT_PASSWORD z pliku `.env` obok docker-compose.yml.
# Port 3307 = mapowanie z docker-compose (host); wewnątrz kontenera MySQL nasłuchuje na 3306.
DATABASE_URL="mysql://root:your_secure_password_here@localhost:3307/socialmgmt"

JWT_SECRET="change-me-to-a-long-random-string-in-production"

# Opcjonalnie: osobny klucz AES dla tokenów Meta w DB (64 znaki hex albo dowolny string → SHA-256)
# TOKEN_ENCRYPTION_KEY=

CLIENT_URL="http://localhost:5173"

# Bazowy URL API (bez końcowego /) — używany m.in. przy zwracaniu pełnego adresu pliku z /api/media/upload
BACKEND_URL="http://localhost:3001"

# Meta / Facebook Developer — https://developers.facebook.com/
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
FACEBOOK_REDIRECT_URI="http://localhost:3001/api/auth/facebook"
# FACEBOOK_API_VERSION="v21.0"

# Limit zapytań/sek. do Graph API (metaGraphFetch). W NODE_ENV=test ignorowany.
# META_GRAPH_MAX_RPS=8
# Górna granica pauzy (s) po nagłówku x-business-use-case-usage (estimated_time_to_regain_access).
# META_GRAPH_MAX_USAGE_COOLDOWN_SEC=300
# Wymuszenie wyłączenia limitu (np. lokalny debug): META_GRAPH_SKIP_RATE_LIMIT=1

# Konto administratora tworzone przez `npm run db:seed` (sekcja „Konto demo” w README).
# Możesz zmienić przed seedem; jeśli zmienisz, loguj się tymi samymi wartościami.
# Zostaw bez zmian, aby używać domyślnego konta demo z dokumentacji.
DEMO_ADMIN_EMAIL=demo@socialmgmt.local
DEMO_ADMIN_PASSWORD=Demo_SocialMgmt_2026!
